{
  "version": 2,
  "builds": [
    {
      "src": "start.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "start.py"
    }
  ],
  "installCommand": "uv sync",
  "buildCommand": "echo 'No build step needed'",
}
